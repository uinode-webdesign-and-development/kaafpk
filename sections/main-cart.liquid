<section class="page-width section-pad">
  <h1 class="h1" style="margin-bottom:2rem;">Your bag</h1>

  {%- if cart.item_count == 0 -%}
    <div class="cart-empty" style="text-align:left;padding-left:0;">
      <p>Your bag is empty.</p>
      <a class="btn btn--primary" href="{{ routes.all_products_collection_url }}">Shop the drop</a>
    </div>
  {%- else -%}
    <form action="{{ routes.cart_url }}" method="post" style="max-width:820px;">
      {%- for item in cart.items -%}
        <div class="cart-line" data-line-key="{{ item.key }}" style="grid-template-columns:90px 1fr auto;">
          <a class="cart-line__media" href="{{ item.url }}">
            {%- if item.image -%}<img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.image.alt | escape }}" width="90" height="112" loading="lazy">{%- endif -%}
          </a>
          <div>
            <a class="cart-line__title" href="{{ item.url }}">{{ item.product.title }}</a>
            {%- unless item.product.has_only_default_variant -%}<div class="cart-line__variant">{{ item.variant.title }}</div>{%- endunless -%}
            <div class="cart-line__price">{{ item.final_line_price | money }}</div>
            <div class="cart-line__qty" data-key="{{ item.key }}">
              <button type="button" data-qty-down aria-label="Decrease">&minus;</button>
              <span>{{ item.quantity }}</span>
              <button type="button" data-qty-up aria-label="Increase">+</button>
            </div>
          </div>
          <button type="button" class="cart-line__remove" data-remove>Remove</button>
        </div>
      {%- endfor -%}

      <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2rem;flex-wrap:wrap;gap:1rem;">
        <div class="cart-subtotal" style="gap:1rem;">
          <span class="muted" style="text-transform:uppercase;letter-spacing:.1em;font-size:.74rem;font-weight:700;">Subtotal</span>
          <span class="price" style="font-family:var(--font-heading);font-size:1.8rem;">{{ cart.total_price | money }}</span>
        </div>
        <button type="submit" name="checkout" class="btn btn--primary btn--lg">Checkout</button>
      </div>
      <p class="cart-note">Shipping &amp; discounts calculated at checkout. COD · JazzCash · Easypaisa · Card.</p>
    </form>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart",
  "tag": "section",
  "settings": []
}
{% endschema %}
