<section class="page-width section-pad">
  {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
    <div class="stack" style="margin-bottom:clamp(24px,4vw,48px);max-width:60ch;" data-reveal>
      {%- if section.settings.eyebrow != blank -%}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="h2">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="editorial editorial--{{ section.blocks.size | at_most: 3 | at_least: 2 }}">
    {%- for block in section.blocks -%}
      <figure class="editorial__tile" {{ block.shopify_attributes }} data-reveal>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 900 }}"
               srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 900 }} 900w, {{ block.settings.image | image_url: width: 1300 }} 1300w"
               sizes="(max-width: 749px) 90vw, 33vw"
               width="{{ block.settings.image.width }}" height="{{ block.settings.image.height }}"
               alt="{{ block.settings.image.alt | default: block.settings.caption | escape }}"
               loading="lazy" decoding="async">
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
        {%- if block.settings.caption != blank or block.settings.link != blank -%}
          <figcaption class="editorial__caption">
            {%- if block.settings.caption != blank -%}<span class="eyebrow">{{ block.settings.caption }}</span>{%- endif -%}
            {%- if block.settings.link != blank -%}
              <div style="margin-top:.5rem;"><a class="link-underline" href="{{ block.settings.link }}">{{ block.settings.link_label | default: 'View' }} {% render 'icon', name: 'arrow-up-right' %}</a></div>
            {%- endif -%}
          </figcaption>
        {%- endif -%}
      </figure>
    {%- else -%}
      {%- for i in (1..3) -%}
        <figure class="editorial__tile">{{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder' }}</figure>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Editorial grid",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "On the block" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Worn in the wild" }
  ],
  "blocks": [
    {
      "type": "shot",
      "name": "Lifestyle shot",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Shop the look" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Editorial grid",
      "blocks": [{ "type": "shot" }, { "type": "shot" }, { "type": "shot" }]
    }
  ]
}
{% endschema %}
