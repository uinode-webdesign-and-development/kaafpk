{%- liquid
  assign has_video = false
  if section.settings.video != blank or section.settings.video_url != blank
    assign has_video = true
  endif
-%}
<section class="hero" data-hero>
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      <video autoplay muted loop playsinline
        {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1600 }}"{% endif %}>
        <source src="{{ section.settings.video.sources[1].url | default: section.settings.video.sources[0].url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.video_url != blank -%}
      <video autoplay muted loop playsinline
        {% if section.settings.image != blank %}poster="{{ section.settings.image | image_url: width: 1600 }}"{% endif %}>
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 2000 }}"
           srcset="{{ section.settings.image | image_url: width: 800 }} 800w, {{ section.settings.image | image_url: width: 1400 }} 1400w, {{ section.settings.image | image_url: width: 2000 }} 2000w"
           sizes="100vw"
           width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}"
           alt="{{ section.settings.image.alt | default: shop.name | escape }}"
           fetchpriority="high" decoding="async">
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder hero__placeholder' }}
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__inner">
    {%- if section.settings.eyebrow != blank -%}
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <h1 class="h-display hero__tagline">{{ section.settings.heading | default: settings.brand_tagline }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="hero__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div class="hero__cta">
      <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="btn btn--primary btn--lg">
        {{ section.settings.cta_label | default: 'Shop the drop' }}
        {% render 'icon', name: 'arrow' %}
      </a>
      {%- if section.settings.cta2_label != blank -%}
        <a href="{{ section.settings.cta2_link }}" class="btn btn--ghost btn--lg">{{ section.settings.cta2_label }}</a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_hint -%}
    <div class="hero__scroll" aria-hidden="true">Scroll</div>
  {%- endif -%}
</section>

{%- comment %} Sticky Shop Now — appears after hero scrolls out {% endcomment -%}
{%- if section.settings.sticky_cta -%}
  <a href="{{ section.settings.cta_link | default: routes.all_products_collection_url }}" class="btn btn--primary sticky-shop" data-sticky-shop>
    {{ section.settings.cta_label | default: 'Shop Now' }}
    {% render 'icon', name: 'arrow' %}
  </a>
{%- endif -%}

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Media" },
    { "type": "image_picker", "id": "image", "label": "Background image (also video poster)" },
    { "type": "video", "id": "video", "label": "Background video (Shopify-hosted)" },
    { "type": "text", "id": "video_url", "label": "…or external MP4 URL" },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Drop 01 — Baggy Set" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Cut loose. Wear heavy." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Oversized, mineral-washed, dropped shoulders. The baggy shirt and trouser built for the streets — sold apart or as the set." },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_label", "label": "Primary button label", "default": "Shop the drop" },
    { "type": "url", "id": "cta_link", "label": "Primary button link" },
    { "type": "text", "id": "cta2_label", "label": "Secondary button label", "default": "The story" },
    { "type": "url", "id": "cta2_link", "label": "Secondary button link" },
    { "type": "checkbox", "id": "sticky_cta", "label": "Show sticky Shop Now button", "default": true },
    { "type": "checkbox", "id": "show_scroll_hint", "label": "Show scroll hint", "default": true }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
