<section class="page-width section-pad" style="max-width:460px;">
  <h1 class="h1" style="margin-bottom:1.5rem;">Reset password</h1>
  {%- form 'reset_customer_password' -%}
    {{ form.errors | default_errors }}
    <div class="stack">
      <input type="password" name="customer[password]" placeholder="New password" required style="width:100%;background:var(--bg-elevated);border:1px solid var(--border-strong);color:var(--text);padding:.85em 1em;border-radius:999px;font-family:inherit;">
      <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required style="width:100%;background:var(--bg-elevated);border:1px solid var(--border-strong);color:var(--text);padding:.85em 1em;border-radius:999px;font-family:inherit;">
      <button type="submit" class="btn btn--primary btn--block">Reset password</button>
    </div>
  {%- endform -%}
</section>
