<section class="page-width section-pad">
  <div style="display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
    <h1 class="h1">Account</h1>
    <a class="link-underline" href="{{ routes.account_logout_url }}">Log out</a>
  </div>
  <p class="muted" style="margin-bottom:2rem;">Welcome back, {{ customer.first_name | default: customer.email }}.</p>

  <h2 class="h3" style="margin-bottom:1rem;">Order history</h2>
  {%- if customer.orders.size > 0 -%}
    <div style="overflow-x:auto;">
      <table class="size-table" style="min-width:520px;">
        <thead><tr><th>Order</th><th>Date</th><th>Total</th><th>Status</th></tr></thead>
        <tbody>
          {%- for order in customer.orders -%}
            <tr>
              <td><a class="accent" href="{{ order.customer_url }}">{{ order.name }}</a></td>
              <td>{{ order.created_at | date: '%d %b %Y' }}</td>
              <td>{{ order.total_price | money }}</td>
              <td>{{ order.fulfillment_status_label }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  {%- else -%}
    <p class="muted">No orders yet.</p>
  {%- endif -%}

  <p style="margin-top:2rem;"><a class="link-underline" href="{{ routes.account_addresses_url }}">Manage addresses ({{ customer.addresses_count }})</a></p>
</section>
