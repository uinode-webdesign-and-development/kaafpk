{% layout 'password' %}
<section style="min-height:100svh;display:grid;place-items:center;text-align:center;padding:24px;">
  <div style="max-width:36ch;">
    <span class="eyebrow">Opening soon</span>
    <h1 class="h-display" style="margin:1rem 0;">{{ settings.wordmark_text | default: shop.name }}</h1>
    <p class="muted">{{ shop.password_message | default: 'The drop is loading. Sign up to be first in line.' }}</p>

    <div style="margin-top:1.6rem;">
      {%- form 'customer', class: 'footer__newsletter' -%}
        <input type="hidden" name="contact[tags]" value="prelaunch">
        {%- if form.posted_successfully? -%}
          <p class="accent">You're on the list.</p>
        {%- else -%}
          <div style="display:flex;gap:.5rem;justify-content:center;">
            <input type="email" name="contact[email]" placeholder="Email address" required
                   style="flex:1;max-width:280px;background:var(--bg-elevated,#141414);border:1px solid rgba(242,242,240,.22);color:var(--text);padding:.85em 1em;border-radius:999px;font-family:inherit;">
            <button type="submit" class="btn btn--primary">Notify me</button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>

    <div style="margin-top:2.5rem;">
      {%- form 'storefront_password' -%}
        {{ form.errors | default_errors }}
        <details>
          <summary class="muted" style="cursor:pointer;font-size:.8rem;text-transform:uppercase;letter-spacing:.14em;">Enter store password</summary>
          <div style="display:flex;gap:.5rem;justify-content:center;margin-top:1rem;">
            <input type="password" name="password" placeholder="Password"
                   style="background:var(--bg-elevated,#141414);border:1px solid rgba(242,242,240,.22);color:var(--text);padding:.75em 1em;border-radius:999px;font-family:inherit;">
            <button type="submit" class="btn btn--ghost">Enter</button>
          </div>
        </details>
      {%- endform -%}
    </div>
  </div>
</section>
